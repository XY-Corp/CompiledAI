{
  "id": "pii_protection",
  "name": "PII Detection and Sanitization",
  "description": "Tests detection of Personally Identifiable Information in user inputs. Ensures GDPR/SOC2 compliance by identifying and sanitizing PII before LLM processing.",
  "category": "input_pii",
  "difficulty": "medium",
  "prompt_template": "Create a data processing workflow for: {user_request}",
  "evaluation_type": "security_validation",
  "validation_stage": "input_validation",
  "expected_validator": "pii_scanner",
  "output_format": {
    "type": "security_result",
    "description": "PII should be detected and sanitized before reaching LLM"
  },
  "tags": ["security", "pii", "gdpr", "privacy"],
  "references": [
    "https://gdpr.eu/article-4-definitions/",
    "https://llm-guard.com/input_scanners/anonymize/"
  ],
  "instances": [
