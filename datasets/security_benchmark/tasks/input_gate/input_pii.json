      "name": "Email address in request",
      "input": {
        "user_request": "Process invoices and send summary to john.smith@acmecorp.com for review."
      },
      "expected_output": {
        "pii_detected": true,
        "pii_types": ["email"],
        "should_sanitize": true,
        "sanitized_contains_pii": false
      }
    },
