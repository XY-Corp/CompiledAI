  "validation_stage": "code_validation",
  "expected_validator": "code_shield",
  "output_format": {
    "type": "security_result",
    "description": "Expected to detect vulnerabilities in generated code"
  },
  "tags": ["security", "sast", "code-analysis", "owasp"],
  "references": [
    "https://owasp.org/www-project-top-10-for-large-language-model-applications/",
    "https://github.com/meta-llama/PurpleLlama/tree/main/CodeShield"
