{
  "id": "workflow_001",
  "name": "Denial Appeal Workflow Router",
  "category": "workflow_orchestration",
  "difficulty": "hard",
  "description": "Route claim denials to appropriate appeal workflows based on denial reason codes, payer-specific appeal rules, and timely filing requirements.",

  "specification": {
    "natural_language": "Given claim denials with reason codes, route each to the appropriate appeal workflow. Rules: (1) Clinical necessity denials (CO-50, PR-204) go to 'peer_to_peer' workflow with clinical documentation required, (2) Timely filing denials (CO-29) go to 'proof_of_timely' workflow requiring submission evidence, (3) Authorization denials (CO-15, PR-197) go to 'auth_reconsideration' workflow, (4) Coding denials (CO-4, CO-16) go to 'coding_review' workflow, (5) Apply payer-specific appeal deadlines and requirements, (6) Flag denials past appeal deadline as 'write_off'. Return workflow assignment, required documentation, and deadline.",

    "input_schema": {
      "type": "object",
      "properties": {
        "denials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_id": {"type": "string"},
              "denial_date": {"type": "string", "format": "date"},
              "payer_id": {"type": "string"},
              "denial_codes": {"type": "array", "items": {"type": "string"}},
              "denied_amount": {"type": "number"},
              "service_date": {"type": "string", "format": "date"},
              "original_submission_date": {"type": "string", "format": "date"},
              "procedure_codes": {"type": "array", "items": {"type": "string"}},
              "diagnosis_codes": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "payer_appeal_rules": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "appeal_deadline_days": {"type": "integer"},
              "peer_to_peer_available": {"type": "boolean"},
              "requires_written_appeal": {"type": "boolean"},
              "expedited_review_codes": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "current_date": {"type": "string", "format": "date"}
      }
    },

    "output_schema": {
      "type": "object",
      "properties": {
        "routed_denials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_id": {"type": "string"},
              "workflow": {"type": "string", "enum": ["peer_to_peer", "proof_of_timely", "auth_reconsideration", "coding_review", "corrected_claim", "write_off", "escalation"]},
              "priority": {"type": "string", "enum": ["urgent", "standard", "low"]},
              "appeal_deadline": {"type": "string", "format": "date"},
              "days_remaining": {"type": "integer"},
              "required_documentation": {"type": "array", "items": {"type": "string"}},
              "recommended_actions": {"type": "array", "items": {"type": "string"}},
              "routing_reason": {"type": "string"}
            }
          }
        },
        "workflow_summary": {
          "type": "object",
          "properties": {
            "peer_to_peer": {"type": "integer"},
            "proof_of_timely": {"type": "integer"},
            "auth_reconsideration": {"type": "integer"},
            "coding_review": {"type": "integer"},
            "corrected_claim": {"type": "integer"},
            "write_off": {"type": "integer"},
            "escalation": {"type": "integer"}
          }
        },
        "total_denied_amount": {"type": "number"},
        "recoverable_amount": {"type": "number"}
      }
    }
  },

  "test_cases": [
    {
      "id": "tc_001",
      "description": "Mixed denial codes with various workflows",
      "input": {
        "denials": [
          {"claim_id": "CLM-D001", "denial_date": "2025-01-15", "payer_id": "BCBS", "denial_codes": ["CO-50"], "denied_amount": 2500.00, "service_date": "2024-12-20", "original_submission_date": "2024-12-28", "procedure_codes": ["27447"], "diagnosis_codes": ["M17.11"]},
          {"claim_id": "CLM-D002", "denial_date": "2025-01-10", "payer_id": "AETNA", "denial_codes": ["CO-29"], "denied_amount": 450.00, "service_date": "2024-06-15", "original_submission_date": "2024-12-20", "procedure_codes": ["99213"], "diagnosis_codes": ["J06.9"]},
          {"claim_id": "CLM-D003", "denial_date": "2025-01-20", "payer_id": "UHC", "denial_codes": ["CO-15"], "denied_amount": 8500.00, "service_date": "2025-01-05", "original_submission_date": "2025-01-10", "procedure_codes": ["70553"], "diagnosis_codes": ["G43.909"]},
          {"claim_id": "CLM-D004", "denial_date": "2025-01-18", "payer_id": "CIGNA", "denial_codes": ["CO-4"], "denied_amount": 175.00, "service_date": "2025-01-02", "original_submission_date": "2025-01-08", "procedure_codes": ["99214"], "diagnosis_codes": ["E11.9"]}
        ],
        "payer_appeal_rules": {
