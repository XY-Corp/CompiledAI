          "write_off": 0,
          "escalation": 1
        },
        "total_denied_amount": 85000.00,
        "recoverable_amount": 85000.00
      }
    }
  ],

  "validation_hints": {
    "denial_code_workflow_mapping": {
      "CO-50": "peer_to_peer",
      "PR-204": "peer_to_peer",
      "CO-29": "proof_of_timely",
      "CO-15": "auth_reconsideration",
      "PR-197": "auth_reconsideration",
      "CO-4": "coding_review",
      "CO-16": "coding_review",
      "MA130": "corrected_claim"
    },
    "escalation_threshold": 50000,
    "priority_rules": {
      "urgent": "days_remaining < 30 OR denied_amount > 10000",
      "standard": "days_remaining >= 30 AND days_remaining < 60",
      "low": "days_remaining >= 60 OR workflow = write_off"
    },
    "multiple_codes_precedence": ["peer_to_peer", "auth_reconsideration", "proof_of_timely", "coding_review", "corrected_claim"]
  }
}
