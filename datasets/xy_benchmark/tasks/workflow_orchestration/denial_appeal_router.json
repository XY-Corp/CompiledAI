          "AETNA": {"appeal_deadline_days": 90, "peer_to_peer_available": false, "requires_written_appeal": true, "expedited_review_codes": []},
          "UHC": {"appeal_deadline_days": 45, "peer_to_peer_available": true, "requires_written_appeal": true, "expedited_review_codes": []},
          "CIGNA": {"appeal_deadline_days": 60, "peer_to_peer_available": false, "requires_written_appeal": false, "expedited_review_codes": []}
