        "current_date": "2025-02-01"
      },
      "expected_output": {
        "routed_denials": [
          {
            "claim_id": "CLM-D001",
            "workflow": "peer_to_peer",
            "priority": "urgent",
            "appeal_deadline": "2025-03-16",
            "days_remaining": 43,
            "required_documentation": ["Medical records", "Clinical notes", "Letter of medical necessity", "Peer-to-peer request form"],
            "recommended_actions": ["Schedule peer-to-peer with medical director", "Prepare clinical justification for knee replacement"],
            "routing_reason": "Clinical necessity denial (CO-50) - peer-to-peer available"
          },
          {
            "claim_id": "CLM-D002",
            "workflow": "proof_of_timely",
            "priority": "standard",
            "appeal_deadline": "2025-04-10",
            "days_remaining": 68,
            "required_documentation": ["Original claim submission confirmation", "Clearinghouse transmission report", "ERA/EOB showing original receipt"],
            "recommended_actions": ["Gather proof of timely filing", "Submit written appeal with transmission evidence"],
            "routing_reason": "Timely filing denial (CO-29) - submission date within payer deadline"
          },
          {
            "claim_id": "CLM-D003",
            "workflow": "auth_reconsideration",
            "priority": "urgent",
            "appeal_deadline": "2025-03-06",
            "days_remaining": 33,
            "required_documentation": ["Prior authorization request records", "Clinical documentation", "Written appeal letter"],
            "recommended_actions": ["Verify if auth was obtained", "If auth exists, submit with appeal", "If no auth, request retroactive authorization"],
            "routing_reason": "Authorization denial (CO-15)"
          },
          {
            "claim_id": "CLM-D004",
            "workflow": "coding_review",
            "priority": "standard",
            "appeal_deadline": "2025-03-19",
            "days_remaining": 46,
            "required_documentation": ["Medical records", "Coding rationale"],
            "recommended_actions": ["Review procedure-diagnosis link", "Verify code selection accuracy", "Submit corrected claim if coding error confirmed"],
            "routing_reason": "Coding/billing denial (CO-4)"
          }
        ],
        "workflow_summary": {
          "peer_to_peer": 1,
          "proof_of_timely": 1,
          "auth_reconsideration": 1,
          "coding_review": 1,
          "corrected_claim": 0,
          "write_off": 0,
          "escalation": 0
        },
        "total_denied_amount": 11625.00,
        "recoverable_amount": 11625.00
      }
    },
    {
