          {"claim_id": "CLM-D031", "denial_date": "2025-01-29", "payer_id": "MEDICARE", "denial_codes": ["CO-4", "MA130"], "denied_amount": 125.00, "service_date": "2025-01-08", "original_submission_date": "2025-01-15", "procedure_codes": ["36415"], "diagnosis_codes": ["Z00.00"]}
