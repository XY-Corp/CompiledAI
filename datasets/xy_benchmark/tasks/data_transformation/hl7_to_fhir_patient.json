  ],

  "validation_hints": {
    "gender_mapping": {"M": "male", "F": "female", "U": "unknown", "O": "other"},
    "identifier_type_fallback": "PI",
    "date_format_input": "YYYYMMDD",
    "date_format_output": "YYYY-MM-DD",
    "name_delimiter": "^",
    "empty_string_is_null": true,
    "ssn_system": "http://hl7.org/fhir/sid/us-ssn",
    "identifier_code_system": "http://terminology.hl7.org/CodeSystem/v2-0203"
  }
}
