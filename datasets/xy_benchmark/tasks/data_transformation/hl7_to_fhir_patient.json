{
  "id": "transform_001",
  "name": "HL7v2 PID to FHIR R4 Patient Transform",
  "category": "data_transformation",
  "difficulty": "hard",
  "description": "Transform HL7v2 PID (Patient Identification) segments into FHIR R4 Patient resources with proper name parsing, identifier mapping, address formatting, and telecom handling.",

  "specification": {
    "natural_language": "Given HL7v2 PID segments, transform each to a FHIR R4 Patient resource. Rules: (1) PID-3 contains patient identifiers - map MRN to 'MR' type, SSN to 'SS' type, (2) PID-5 contains name in format 'LAST^FIRST^MIDDLE' - parse into HumanName with family, given[], (3) PID-7 is DOB in format 'YYYYMMDD' - convert to 'YYYY-MM-DD', (4) PID-8 is gender 'M'/'F'/'U' - map to 'male'/'female'/'unknown', (5) PID-11 contains address - parse into Address resource, (6) PID-13/14 contain phone/work - map to telecom ContactPoints.",

    "input_schema": {
      "type": "object",
      "properties": {
        "pid_segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pid_3_identifiers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "type": {"type": "string"},
                    "assigning_authority": {"type": "string"}
                  }
                }
              },
              "pid_5_name": {"type": "string"},
              "pid_7_dob": {"type": "string"},
              "pid_8_gender": {"type": "string"},
              "pid_11_address": {
                "type": "object",
                "properties": {
                  "street": {"type": "string"},
                  "city": {"type": "string"},
                  "state": {"type": "string"},
                  "postal_code": {"type": "string"},
                  "country": {"type": "string"}
                }
              },
              "pid_13_home_phone": {"type": "string"},
              "pid_14_work_phone": {"type": "string"},
              "pid_40_email": {"type": "string"}
            }
          }
        }
      }
    },

    "output_schema": {
      "type": "object",
      "properties": {
        "fhir_patients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resourceType": {"type": "string", "const": "Patient"},
              "identifier": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "object",
                      "properties": {
                        "coding": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "system": {"type": "string"},
                              "code": {"type": "string"}
                            }
                          }
                        }
                      }
                    },
                    "system": {"type": "string"},
                    "value": {"type": "string"}
                  }
                }
              },
              "name": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "use": {"type": "string"},
                    "family": {"type": "string"},
                    "given": {"type": "array", "items": {"type": "string"}}
                  }
                }
              },
              "gender": {"type": "string", "enum": ["male", "female", "other", "unknown"]},
              "birthDate": {"type": "string", "format": "date"},
              "address": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "use": {"type": "string"},
                    "line": {"type": "array", "items": {"type": "string"}},
                    "city": {"type": "string"},
                    "state": {"type": "string"},
                    "postalCode": {"type": "string"},
                    "country": {"type": "string"}
                  }
                }
              },
              "telecom": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "system": {"type": "string"},
                    "value": {"type": "string"},
                    "use": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "transform_summary": {
          "type": "object",
          "properties": {
            "total_processed": {"type": "integer"},
            "successful": {"type": "integer"},
            "warnings": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    }
  },

  "test_cases": [
    {
      "id": "tc_001",
      "description": "Complete patient record with all fields",
      "input": {
        "pid_segments": [
          {
            "pid_3_identifiers": [
              {"id": "12345678", "type": "MR", "assigning_authority": "HOSPITAL_A"},
              {"id": "123-45-6789", "type": "SS", "assigning_authority": "SSA"}
            ],
            "pid_5_name": "SMITH^JOHN^WILLIAM",
            "pid_7_dob": "19850315",
            "pid_8_gender": "M",
            "pid_11_address": {
              "street": "123 Main Street",
              "city": "Boston",
              "state": "MA",
              "postal_code": "02101",
              "country": "USA"
            },
            "pid_13_home_phone": "(617) 555-1234",
            "pid_14_work_phone": "(617) 555-5678",
            "pid_40_email": "john.smith@email.com"
          }
        ]
      },
      "expected_output": {
        "fhir_patients": [
          {
            "resourceType": "Patient",
            "identifier": [
              {
                "type": {
                  "coding": [{"system": "http://terminology.hl7.org/CodeSystem/v2-0203", "code": "MR"}]
                },
                "system": "urn:oid:HOSPITAL_A",
                "value": "12345678"
              },
              {
                "type": {
                  "coding": [{"system": "http://terminology.hl7.org/CodeSystem/v2-0203", "code": "SS"}]
                },
                "system": "http://hl7.org/fhir/sid/us-ssn",
                "value": "123-45-6789"
              }
            ],
            "name": [
              {
                "use": "official",
                "family": "SMITH",
                "given": ["JOHN", "WILLIAM"]
              }
            ],
            "gender": "male",
            "birthDate": "1985-03-15",
            "address": [
              {
                "use": "home",
                "line": ["123 Main Street"],
                "city": "Boston",
                "state": "MA",
                "postalCode": "02101",
                "country": "USA"
              }
            ],
            "telecom": [
              {"system": "phone", "value": "(617) 555-1234", "use": "home"},
              {"system": "phone", "value": "(617) 555-5678", "use": "work"},
              {"system": "email", "value": "john.smith@email.com", "use": "home"}
            ]
          }
        ],
        "transform_summary": {
          "total_processed": 1,
          "successful": 1,
          "warnings": []
        }
      }
    },
