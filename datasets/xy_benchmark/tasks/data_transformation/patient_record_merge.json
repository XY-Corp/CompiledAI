{
  "id": "data_001",
  "name": "Patient Record Merge",
  "category": "data_transformation",
  "difficulty": "hard",
  "description": "Merge patient records from two healthcare systems, resolving conflicts using priority rules and tracking data lineage.",
  
  "specification": {
    "natural_language": "Given patient records from System A (EHR) and System B (billing), merge into a single canonical record. System A is authoritative for clinical data (allergies, conditions). System B is authoritative for insurance data. For demographics, prefer most recently updated. Track which system each field came from.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "system_a_record": {
          "type": "object",
          "properties": {
            "patient_id": {"type": "string"},
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string", "format": "date"},
            "phone": {"type": "string"},
            "allergies": {"type": "array", "items": {"type": "string"}},
            "conditions": {"type": "array", "items": {"type": "string"}},
            "last_updated": {"type": "string", "format": "date-time"}
          }
        },
        "system_b_record": {
          "type": "object",
          "properties": {
            "patient_id": {"type": "string"},
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string", "format": "date"},
            "phone": {"type": "string"},
            "insurance_id": {"type": "string"},
            "insurance_plan": {"type": "string"},
            "copay": {"type": "number"},
            "last_updated": {"type": "string", "format": "date-time"}
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "merged_record": {
          "type": "object",
          "properties": {
            "patient_id": {"type": "string"},
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string"},
            "phone": {"type": "string"},
            "allergies": {"type": "array"},
            "conditions": {"type": "array"},
            "insurance_id": {"type": "string"},
            "insurance_plan": {"type": "string"},
            "copay": {"type": "number"}
          }
        },
        "lineage": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "conflicts_resolved": {"type": "integer"}
      }
    }
  },
  
