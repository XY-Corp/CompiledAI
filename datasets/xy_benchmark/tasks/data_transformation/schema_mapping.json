{
  "id": "data_002",
  "name": "Healthcare Schema Mapping",
  "category": "data_transformation",
  "difficulty": "medium",
  "description": "Map records from a legacy healthcare schema to FHIR-compliant format with field transformations.",
  
  "specification": {
    "natural_language": "Convert patient encounter records from a legacy EHR format to FHIR-compliant structure. Map field names, transform date formats (MM/DD/YYYY to ISO 8601), convert status codes (A/I/D to active/inactive/deleted), and split full names into given/family components.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "encounters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ENCNTR_ID": {"type": "string"},
              "PAT_NAME": {"type": "string"},
              "PAT_DOB": {"type": "string"},
              "VISIT_DT": {"type": "string"},
              "VISIT_TYPE_CD": {"type": "string"},
              "PROV_NAME": {"type": "string"},
              "STATUS_CD": {"type": "string"},
              "DIAG_CD": {"type": "string"},
              "NOTES_TXT": {"type": "string"}
            }
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "fhir_encounters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resourceType": {"type": "string", "const": "Encounter"},
              "id": {"type": "string"},
              "status": {"type": "string"},
              "subject": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "object",
                    "properties": {
                      "given": {"type": "array", "items": {"type": "string"}},
                      "family": {"type": "string"}
                    }
                  },
                  "birthDate": {"type": "string", "format": "date"}
                }
              },
              "period": {
                "type": "object",
                "properties": {
                  "start": {"type": "string", "format": "date"}
                }
              },
              "type": {"type": "string"},
              "participant": {"type": "string"},
              "diagnosis": {"type": "string"},
              "note": {"type": "string"}
            }
          }
        },
        "mapping_stats": {
          "type": "object",
          "properties": {
            "total_records": {"type": "integer"},
            "successful": {"type": "integer"},
            "warnings": {"type": "integer"}
          }
        }
      }
    }
  },
  
  "test_cases": [
    {
      "id": "tc_001",
      "input": {
        "encounters": [
          {
            "ENCNTR_ID": "E001",
