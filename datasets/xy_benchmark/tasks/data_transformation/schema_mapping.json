            "DIAG_CD": "F41.1",
            "NOTES_TXT": ""
          }
        ]
      },
      "expected_output": {
        "fhir_encounters": [
          {
            "resourceType": "Encounter",
            "id": "E001",
            "status": "active",
            "subject": {
              "name": {
                "given": ["John", "Michael"],
                "family": "Smith"
              },
              "birthDate": "1985-03-15"
            },
            "period": {"start": "2025-01-20"},
            "type": "OFFICE",
            "participant": "Dr. Jane Wilson",
            "diagnosis": "J06.9",
            "note": "Follow-up for URI symptoms"
          },
          {
            "resourceType": "Encounter",
            "id": "E002",
            "status": "inactive",
            "subject": {
              "name": {
                "given": ["Jane"],
                "family": "Doe"
              },
              "birthDate": "1990-07-22"
            },
            "period": {"start": "2025-01-21"},
            "type": "TELEHEALTH",
            "participant": "Dr. Bob Johnson",
            "diagnosis": "F41.1",
            "note": ""
          }
