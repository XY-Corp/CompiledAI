  "validation_hints": {
    "name_parsing": "Format is 'Last, First Middle' - split on comma, then space",
    "date_format": "MM/DD/YYYY to YYYY-MM-DD",
    "status_mapping": {"A": "active", "I": "inactive", "D": "deleted"}
  }
}
