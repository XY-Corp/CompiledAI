{
  "id": "data_003",
  "name": "Appointment Schedule Aggregation",
  "category": "data_transformation",
  "difficulty": "medium",
  "description": "Aggregate appointment data by provider and time slot to generate schedule utilization metrics.",
  
  "specification": {
    "natural_language": "Given a list of appointments, aggregate by provider to calculate: total appointments, completed vs cancelled vs no-show counts, average duration, utilization rate (scheduled hours / available hours), and revenue totals. Group by provider and sort by utilization rate descending.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "date": {"type": "string", "format": "date"},
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider_id": {"type": "string"},
              "name": {"type": "string"},
              "available_hours": {"type": "number"}
            }
          }
        },
        "appointments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "appointment_id": {"type": "string"},
              "provider_id": {"type": "string"},
              "patient_name": {"type": "string"},
              "start_time": {"type": "string"},
              "duration_minutes": {"type": "integer"},
              "status": {"type": "string", "enum": ["completed", "cancelled", "no_show", "scheduled"]},
              "charge_amount": {"type": "number"}
            }
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "date": {"type": "string"},
        "provider_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider_id": {"type": "string"},
              "provider_name": {"type": "string"},
              "total_appointments": {"type": "integer"},
              "completed": {"type": "integer"},
              "cancelled": {"type": "integer"},
              "no_show": {"type": "integer"},
              "scheduled_hours": {"type": "number"},
              "available_hours": {"type": "number"},
              "utilization_rate": {"type": "number"},
              "total_revenue": {"type": "number"},
              "avg_duration_minutes": {"type": "number"}
            }
          }
        },
        "totals": {
          "type": "object",
          "properties": {
            "total_appointments": {"type": "integer"},
            "total_revenue": {"type": "number"},
            "overall_utilization": {"type": "number"}
          }
        }
      }
    }
  },
  
  "test_cases": [
    {
      "id": "tc_001",
      "input": {
        "date": "2025-01-20",
        "providers": [
          {"provider_id": "DR001", "name": "Dr. Smith", "available_hours": 8},
          {"provider_id": "DR002", "name": "Dr. Jones", "available_hours": 8}
        ],
        "appointments": [
          {"appointment_id": "A001", "provider_id": "DR001", "patient_name": "Patient A", "start_time": "09:00", "duration_minutes": 30, "status": "completed", "charge_amount": 150.00},
          {"appointment_id": "A002", "provider_id": "DR001", "patient_name": "Patient B", "start_time": "09:30", "duration_minutes": 30, "status": "completed", "charge_amount": 150.00},
          {"appointment_id": "A003", "provider_id": "DR001", "patient_name": "Patient C", "start_time": "10:00", "duration_minutes": 60, "status": "cancelled", "charge_amount": 0.00},
          {"appointment_id": "A004", "provider_id": "DR002", "patient_name": "Patient D", "start_time": "09:00", "duration_minutes": 45, "status": "completed", "charge_amount": 200.00},
          {"appointment_id": "A005", "provider_id": "DR002", "patient_name": "Patient E", "start_time": "10:00", "duration_minutes": 30, "status": "no_show", "charge_amount": 0.00}
        ]
      },
      "expected_output": {
        "date": "2025-01-20",
        "provider_metrics": [
          {"provider_id": "DR001", "provider_name": "Dr. Smith", "total_appointments": 3, "completed": 2, "cancelled": 1, "no_show": 0, "scheduled_hours": 2.0, "available_hours": 8, "utilization_rate": 0.25, "total_revenue": 300.00, "avg_duration_minutes": 40.0},
          {"provider_id": "DR002", "provider_name": "Dr. Jones", "total_appointments": 2, "completed": 1, "cancelled": 0, "no_show": 1, "scheduled_hours": 1.25, "available_hours": 8, "utilization_rate": 0.16, "total_revenue": 200.00, "avg_duration_minutes": 37.5}
        ],
        "totals": {"total_appointments": 5, "total_revenue": 500.00, "overall_utilization": 0.20}
      }
    },
    {
      "id": "tc_002",
      "input": {
