{
  "id": "api_002",
  "name": "Patient Onboarding Orchestration",
  "category": "api_orchestration",
  "difficulty": "hard",
  "description": "Orchestrate a multi-step patient onboarding flow across multiple systems: EHR, billing, portal, and notifications.",
  
  "specification": {
    "natural_language": "Process a new patient registration by: (1) Create patient record in EHR, (2) Set up billing account with insurance info, (3) Create patient portal account, (4) Send welcome notifications (email + SMS). Track success/failure of each step, handle partial failures gracefully, and return overall status.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "registration_id": {"type": "string"},
        "patient_info": {
          "type": "object",
          "properties": {
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string"},
            "email": {"type": "string"},
            "phone": {"type": "string"},
            "address": {"type": "string"}
          }
        },
        "insurance_info": {
          "type": "object",
          "properties": {
            "payer_id": {"type": "string"},
            "member_id": {"type": "string"},
            "group_number": {"type": "string"}
          }
        },
        "preferences": {
          "type": "object",
          "properties": {
            "portal_access": {"type": "boolean"},
            "email_notifications": {"type": "boolean"},
            "sms_notifications": {"type": "boolean"}
          }
        },
        "system_status": {
          "type": "object",
          "properties": {
            "ehr_available": {"type": "boolean"},
            "billing_available": {"type": "boolean"},
            "portal_available": {"type": "boolean"},
            "notification_available": {"type": "boolean"}
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "registration_id": {"type": "string"},
        "overall_status": {"type": "string", "enum": ["success", "partial_success", "failed"]},
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step_name": {"type": "string"},
              "status": {"type": "string", "enum": ["success", "failed", "skipped"]},
              "system_id": {"type": "string"},
              "error_message": {"type": "string"}
            }
          }
        },
        "created_ids": {
          "type": "object",
          "properties": {
            "ehr_patient_id": {"type": "string"},
            "billing_account_id": {"type": "string"},
            "portal_user_id": {"type": "string"}
          }
        },
        "notifications_sent": {
          "type": "object",
          "properties": {
            "email": {"type": "boolean"},
            "sms": {"type": "boolean"}
          }
        },
        "requires_manual_followup": {"type": "boolean"},
        "followup_items": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  
  "test_cases": [
    {
      "id": "tc_001",
      "description": "Full success - all systems available, all preferences enabled",
      "input": {
        "registration_id": "REG-001",
        "patient_info": {
          "first_name": "John",
          "last_name": "Smith",
          "dob": "1985-03-15",
          "email": "john.smith@email.com",
          "phone": "555-0101",
          "address": "123 Main St, Anytown, ST 12345"
        },
        "insurance_info": {
          "payer_id": "BCBS",
          "member_id": "XYZ123456",
          "group_number": "GRP001"
        },
        "preferences": {
          "portal_access": true,
          "email_notifications": true,
          "sms_notifications": true
        },
        "system_status": {
          "ehr_available": true,
          "billing_available": true,
          "portal_available": true,
          "notification_available": true
        }
      },
      "expected_output": {
        "registration_id": "REG-001",
        "overall_status": "success",
        "steps": [
          {"step_name": "create_ehr_patient", "status": "success", "system_id": "EHR-P001", "error_message": ""},
          {"step_name": "create_billing_account", "status": "success", "system_id": "BILL-A001", "error_message": ""},
          {"step_name": "create_portal_account", "status": "success", "system_id": "PORT-U001", "error_message": ""},
          {"step_name": "send_email_notification", "status": "success", "system_id": "NOTIF-E001", "error_message": ""},
          {"step_name": "send_sms_notification", "status": "success", "system_id": "NOTIF-S001", "error_message": ""}
        ],
        "created_ids": {
          "ehr_patient_id": "EHR-P001",
          "billing_account_id": "BILL-A001",
          "portal_user_id": "PORT-U001"
        },
        "notifications_sent": {"email": true, "sms": true},
        "requires_manual_followup": false,
        "followup_items": []
      }
    },
