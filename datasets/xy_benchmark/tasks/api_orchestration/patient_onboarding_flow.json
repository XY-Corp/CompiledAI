  "validation_hints": {
    "critical_systems": ["ehr_available"],
    "step_dependency": "EHR must succeed before billing/portal can proceed",
    "id_generation": "Use registration suffix (REG-001 → EHR-P001, BILL-A001, etc.)",
    "overall_status_rules": {
      "success": "all critical steps succeeded",
      "partial_success": "EHR succeeded but other steps failed",
      "failed": "EHR failed"
    }
  }
}
