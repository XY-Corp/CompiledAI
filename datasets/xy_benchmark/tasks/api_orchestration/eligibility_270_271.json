  ],

  "validation_hints": {
    "service_type_code_mapping": {
      "30": "Health Benefit Plan Coverage",
      "33": "Chiropractic",
      "47": "Hospital",
      "48": "Hospital Inpatient",
      "50": "Hospital Outpatient",
      "86": "Emergency Services",
      "88": "Pharmacy",
      "98": "Professional Physician Visit",
      "AL": "Vision",
      "AJ": "Dental"
    },
    "network_check": "provider_npi in network_providers array",
    "coverage_date_check": "service_date between coverage_start and coverage_end",
    "response_code_reference": "X12 271 AAA segment codes"
  }
}
