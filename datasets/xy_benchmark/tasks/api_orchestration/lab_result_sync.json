{
  "id": "api_001",
  "name": "Lab Result System Sync",
  "category": "api_orchestration",
  "difficulty": "hard",
  "description": "Orchestrate syncing lab results from an external lab system to an EHR, with patient matching, result normalization, and notification triggers.",
  
  "specification": {
    "natural_language": "Given a batch of lab results from an external system, orchestrate the sync process: (1) match each result to a patient in the EHR using MRN or DOB+name, (2) normalize lab values to standard units, (3) determine if any results are critical and require immediate notification, (4) prepare the upsert payload for each result. Return sync summary with any failures.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "batch_id": {"type": "string"},
        "lab_results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "external_id": {"type": "string"},
              "patient_mrn": {"type": "string"},
              "patient_name": {"type": "string"},
              "patient_dob": {"type": "string", "format": "date"},
              "test_code": {"type": "string"},
              "test_name": {"type": "string"},
              "value": {"type": "number"},
              "unit": {"type": "string"},
              "reference_low": {"type": "number"},
              "reference_high": {"type": "number"},
              "collected_at": {"type": "string", "format": "date-time"},
              "resulted_at": {"type": "string", "format": "date-time"}
            }
          }
        },
        "ehr_patients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ehr_patient_id": {"type": "string"},
              "mrn": {"type": "string"},
              "first_name": {"type": "string"},
              "last_name": {"type": "string"},
              "dob": {"type": "string", "format": "date"}
            }
          }
        },
        "critical_thresholds": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "critical_low": {"type": "number"},
              "critical_high": {"type": "number"}
            }
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "batch_id": {"type": "string"},
        "sync_results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "external_id": {"type": "string"},
              "status": {"type": "string", "enum": ["matched", "unmatched", "error"]},
              "ehr_patient_id": {"type": "string"},
              "normalized_value": {"type": "number"},
              "normalized_unit": {"type": "string"},
              "is_critical": {"type": "boolean"},
              "critical_type": {"type": "string", "enum": ["high", "low", null]},
              "notification_required": {"type": "boolean"}
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total": {"type": "integer"},
            "matched": {"type": "integer"},
            "unmatched": {"type": "integer"},
            "critical_count": {"type": "integer"},
            "notifications_triggered": {"type": "integer"}
          }
        }
      }
    }
  },
  
  "test_cases": [
    {
