  "validation_hints": {
    "patient_matching": "Match by MRN first, then fallback to DOB + last name",
    "critical_check": "Value outside critical_low/critical_high triggers notification",
    "normalization": "Keep original units in this version",
    "boundary_values": "Values exactly at critical thresholds are NOT critical (strict inequality)"
  }
