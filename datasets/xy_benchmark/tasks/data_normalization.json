{
  "id": "normalize_01",
  "name": "Address Normalization",
  "description": "Normalize addresses to standard format",
  "category": "data_transformation",
  "difficulty": "medium",
  "prompt_template": "Normalize this address to the standard format:\n{address}\n\nReturn JSON with: street, city, state, zip, country",
  "evaluation_type": "schema",
  "schema": {
    "type": "object",
    "properties": {
      "street": {"type": "string"},
      "city": {"type": "string"},
      "state": {"type": "string"},
      "zip": {"type": "string"},
      "country": {"type": "string"}
    },
    "required": ["street", "city", "state", "zip", "country"]
  },
  "tags": ["normalization", "address"],
  "instances": [
    {
      "id": "addr_001",
      "input": {
        "address": "123 Main St., Apt 4B, New York, NY 10001"
      },
      "expected_output": {
        "street": "123 Main St Apt 4B",
        "city": "New York",
        "state": "NY",
        "zip": "10001",
        "country": "USA"
      }
    },
    {
      "id": "addr_002",
      "input": {
        "address": "456 Oak Avenue, Suite 100, Los Angeles, California, 90001, United States"
      },
      "expected_output": {
        "street": "456 Oak Avenue Suite 100",
        "city": "Los Angeles",
        "state": "CA",
        "zip": "90001",
        "country": "USA"
      }
    }
  ]
}
