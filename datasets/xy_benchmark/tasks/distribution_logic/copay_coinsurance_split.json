            "allowed_amount": 150.00,
            "deductible_applied": 150.00,
            "copay_applied": 0.00,
            "coinsurance_applied": 0.00,
            "patient_responsibility": 150.00,
            "payer_responsibility": 0.00,
            "oop_cap_applied": false
          },
          {
            "service_id": "SVC-002",
            "allowed_amount": 120.00,
            "deductible_applied": 95.00,
            "copay_applied": 25.00,
            "coinsurance_applied": 0.00,
            "patient_responsibility": 120.00,
            "payer_responsibility": 0.00,
            "oop_cap_applied": false
          },
          {
            "service_id": "SVC-003",
            "allowed_amount": 500.00,
            "deductible_applied": 500.00,
            "copay_applied": 0.00,
            "coinsurance_applied": 0.00,
            "patient_responsibility": 500.00,
            "payer_responsibility": 0.00,
            "oop_cap_applied": false
          }
        ],
        "updated_accumulators": {
          "deductible_met": 745.00,
          "out_of_pocket_met": 770.00,
          "deductible_remaining": 255.00,
          "oop_remaining": 4230.00
