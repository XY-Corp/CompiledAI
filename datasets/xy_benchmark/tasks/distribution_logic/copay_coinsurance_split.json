{
  "id": "distribution_001",
  "name": "Copay and Coinsurance Distribution Calculator",
  "category": "distribution_logic",
  "difficulty": "hard",
  "description": "Calculate patient vs payer responsibility given plan design (deductible, copay, coinsurance%, OOP max) and YTD accumulators for a list of services.",

  "specification": {
    "natural_language": "Given a health plan design and year-to-date accumulators, calculate cost sharing for each service. Rules: (1) Apply remaining deductible first to allowed amount, (2) After deductible, apply copay if fixed copay service, otherwise apply coinsurance percentage, (3) Patient responsibility capped at remaining OOP max, (4) Track accumulator updates across services in order. Return per-service breakdown and updated accumulators.",

    "input_schema": {
      "type": "object",
      "properties": {
        "plan_design": {
          "type": "object",
          "properties": {
            "annual_deductible": {"type": "number"},
            "coinsurance_percent": {"type": "number", "minimum": 0, "maximum": 100},
            "out_of_pocket_max": {"type": "number"},
            "copay_services": {
              "type": "object",
              "additionalProperties": {"type": "number"}
            }
          }
        },
        "ytd_accumulators": {
          "type": "object",
          "properties": {
            "deductible_met": {"type": "number"},
            "out_of_pocket_met": {"type": "number"}
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_id": {"type": "string"},
              "service_type": {"type": "string"},
              "allowed_amount": {"type": "number"},
              "service_date": {"type": "string", "format": "date"}
            }
          }
        }
      }
    },

    "output_schema": {
      "type": "object",
      "properties": {
        "service_calculations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_id": {"type": "string"},
              "allowed_amount": {"type": "number"},
              "deductible_applied": {"type": "number"},
              "copay_applied": {"type": "number"},
              "coinsurance_applied": {"type": "number"},
              "patient_responsibility": {"type": "number"},
              "payer_responsibility": {"type": "number"},
              "oop_cap_applied": {"type": "boolean"}
            }
          }
        },
        "updated_accumulators": {
          "type": "object",
          "properties": {
            "deductible_met": {"type": "number"},
            "out_of_pocket_met": {"type": "number"},
            "deductible_remaining": {"type": "number"},
            "oop_remaining": {"type": "number"}
          }
        },
        "totals": {
          "type": "object",
          "properties": {
            "total_allowed": {"type": "number"},
            "total_patient": {"type": "number"},
            "total_payer": {"type": "number"}
          }
        }
      }
    }
  },

  "test_cases": [
    {
      "id": "tc_001",
      "description": "Standard plan with deductible not yet met",
      "input": {
        "plan_design": {
          "annual_deductible": 1000.00,
          "coinsurance_percent": 20,
          "out_of_pocket_max": 5000.00,
          "copay_services": {
            "office_visit": 25.00,
            "specialist": 50.00
          }
        },
        "ytd_accumulators": {
          "deductible_met": 0.00,
          "out_of_pocket_met": 0.00
        },
        "services": [
          {"service_id": "SVC-001", "service_type": "lab", "allowed_amount": 150.00, "service_date": "2025-02-01"},
          {"service_id": "SVC-002", "service_type": "office_visit", "allowed_amount": 120.00, "service_date": "2025-02-01"},
          {"service_id": "SVC-003", "service_type": "imaging", "allowed_amount": 500.00, "service_date": "2025-02-05"}
