  "validation_hints": {
    "processing_order": "services processed in array order",
    "deductible_first": true,
    "copay_vs_coinsurance": "copay replaces coinsurance for defined service types",
    "oop_includes_deductible": true,
    "oop_includes_copay": true,
    "oop_includes_coinsurance": true,
    "rounding": "round_half_up_to_cents"
  }
}
