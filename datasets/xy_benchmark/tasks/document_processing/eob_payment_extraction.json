{
  "id": "doc_001",
  "name": "Insurance Payment Extraction",
  "category": "document_processing",
  "difficulty": "medium",
  "description": "Extract payment line items from an insurance Explanation of Benefits (EOB) document, calculate totals, and flag discrepancies.",
  "specification": {
    "natural_language": "Given an EOB document with patient info, payer details, and payment line items, extract all payments into a structured format. Calculate the total billed, allowed, and paid amounts. Flag any line item where the paid amount differs from allowed by more than 5%.",
    "input_schema": {
      "type": "object",
      "properties": {
        "document_id": {
          "type": "string"
        },
        "patient": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "dob": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "payer": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "plan_id": {
              "type": "string"
            }
          }
        },
        "service_date": {
          "type": "string",
          "format": "date"
        },
        "line_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_code": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "billed_amount": {
                "type": "number"
              },
              "allowed_amount": {
                "type": "number"
              },
              "paid_amount": {
                "type": "number"
              },
              "adjustment_reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "document_id": {
          "type": "string"
        },
        "patient_id": {
          "type": "string"
        },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_code": {
                "type": "string"
              },
              "billed": {
                "type": "number"
              },
              "allowed": {
                "type": "number"
              },
              "paid": {
                "type": "number"
              },
              "variance_flag": {
                "type": "boolean"
              }
            }
          }
        },
        "totals": {
          "type": "object",
          "properties": {
            "total_billed": {
              "type": "number"
            },
            "total_allowed": {
              "type": "number"
            },
            "total_paid": {
              "type": "number"
            }
          }
        },
        "flagged_count": {
          "type": "integer"
        }
      }
    }
  },
  "test_cases": [
    {
      "id": "tc_001",
      "input": {
        "document_id": "EOB-2025-001",
        "patient": {
          "id": "P123",
