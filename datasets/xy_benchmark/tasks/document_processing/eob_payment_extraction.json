            "paid_amount": 15.0,
            "adjustment_reason": "plan limitation"
          }
        ]
      },
      "expected_output": {
        "document_id": "EOB-2025-001",
        "patient_id": "P123",
        "payments": [
          {
            "service_code": "99213",
            "billed": 150.0,
            "allowed": 120.0,
            "paid": 120.0,
            "variance_flag": false
          },
          {
            "service_code": "85025",
            "billed": 45.0,
            "allowed": 35.0,
            "paid": 35.0,
            "variance_flag": false
          },
          {
            "service_code": "36415",
            "billed": 25.0,
            "allowed": 20.0,
            "paid": 15.0,
            "variance_flag": true
          }
        ],
        "totals": {
          "total_billed": 220.0,
          "total_allowed": 175.0,
          "total_paid": 170.0
        },
        "flagged_count": 1
      }
    },
