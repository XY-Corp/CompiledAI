{
  "id": "doc_004",
  "name": "Remittance Advice Parser",
  "category": "document_processing",
  "difficulty": "hard",
  "description": "Parse ERA (Electronic Remittance Advice) data to extract payment details, adjustments, and reconciliation information.",
  
  "specification": {
    "natural_language": "Parse an 835 ERA document containing payment information from a payer. Extract claim-level payments, adjustment codes with amounts, patient responsibility, and calculate payment reconciliation totals. Group by claim and flag any claims with unexpected denials.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "era_id": {"type": "string"},
        "payer": {"type": "string"},
        "payment_date": {"type": "string"},
        "check_number": {"type": "string"},
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_id": {"type": "string"},
              "patient_name": {"type": "string"},
              "service_date": {"type": "string"},
              "billed_amount": {"type": "number"},
              "adjustments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "code": {"type": "string"},
                    "reason": {"type": "string"},
                    "amount": {"type": "number"}
                  }
                }
              },
              "paid_amount": {"type": "number"},
              "patient_responsibility": {"type": "number"}
            }
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "era_id": {"type": "string"},
        "summary": {
          "type": "object",
          "properties": {
            "payer": {"type": "string"},
            "check_number": {"type": "string"},
            "payment_date": {"type": "string"},
            "total_billed": {"type": "number"},
            "total_adjustments": {"type": "number"},
            "total_paid": {"type": "number"},
            "total_patient_responsibility": {"type": "number"}
          }
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_id": {"type": "string"},
              "patient_name": {"type": "string"},
              "billed": {"type": "number"},
              "adjustments_total": {"type": "number"},
              "paid": {"type": "number"},
              "patient_resp": {"type": "number"},
              "adjustment_codes": {"type": "array"},
              "has_denial": {"type": "boolean"}
            }
          }
        },
        "denial_claims": {"type": "array", "items": {"type": "string"}},
        "reconciliation_balanced": {"type": "boolean"}
      }
    }
  },
  
  "test_cases": [
    {
      "id": "tc_001",
      "input": {
        "era_id": "ERA-2025-001",
        "payer": "BlueCross BlueShield",
        "payment_date": "2025-01-25",
        "check_number": "CHK-987654",
        "claims": [
          {
            "claim_id": "CLM-001",
            "patient_name": "John Smith",
            "service_date": "2025-01-10",
            "billed_amount": 500.00,
            "adjustments": [
              {"code": "CO-45", "reason": "Contractual adjustment", "amount": 150.00}
            ],
            "paid_amount": 350.00,
            "patient_responsibility": 0.00
          },
          {
            "claim_id": "CLM-002",
            "patient_name": "Jane Doe",
            "service_date": "2025-01-12",
            "billed_amount": 200.00,
            "adjustments": [
              {"code": "CO-45", "reason": "Contractual adjustment", "amount": 50.00},
              {"code": "PR-1", "reason": "Deductible", "amount": 25.00}
            ],
            "paid_amount": 125.00,
            "patient_responsibility": 25.00
          }
        ]
      },
      "expected_output": {
        "era_id": "ERA-2025-001",
        "summary": {
          "payer": "BlueCross BlueShield",
          "check_number": "CHK-987654",
          "payment_date": "2025-01-25",
          "total_billed": 700.00,
          "total_adjustments": 225.00,
          "total_paid": 475.00,
          "total_patient_responsibility": 25.00
        },
        "claims": [
          {"claim_id": "CLM-001", "patient_name": "John Smith", "billed": 500.00, "adjustments_total": 150.00, "paid": 350.00, "patient_resp": 0.00, "adjustment_codes": ["CO-45"], "has_denial": false},
          {"claim_id": "CLM-002", "patient_name": "Jane Doe", "billed": 200.00, "adjustments_total": 75.00, "paid": 125.00, "patient_resp": 25.00, "adjustment_codes": ["CO-45", "PR-1"], "has_denial": false}
        ],
        "denial_claims": [],
        "reconciliation_balanced": true
      }
    },
