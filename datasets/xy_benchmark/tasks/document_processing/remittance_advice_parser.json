  "validation_hints": {
    "denial_codes": ["CO-4", "CO-16", "CO-18", "CO-27", "CO-29", "CO-50"],
    "reconciliation_check": "billed = adjustments + paid + patient_resp",
    "pr_codes_are_patient_resp": "PR-* codes indicate patient responsibility"
  }
