  "validation_hints": {
    "required_fields": ["first_name", "last_name", "dob", "phone"],
    "phone_normalization": "Remove non-digits, format as (XXX) XXX-XXXX",
    "list_splitting": "Split on comma, trim whitespace",
    "none_handling": "'None' or 'N/A' becomes empty array",
    "completeness_calculation": "13 total fields, score = (filled_count / 13) * 100"
  }
