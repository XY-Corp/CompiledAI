{
  "id": "doc_003",
  "name": "Medical Form Data Extraction",
  "category": "document_processing",
  "difficulty": "medium",
  "description": "Extract patient intake form data into structured format with field validation and completeness scoring.",
  
  "specification": {
    "natural_language": "Parse a patient intake form containing demographics, medical history, and current medications. Validate required fields are present, normalize phone numbers to (XXX) XXX-XXXX format, and calculate a completeness score (0-100) based on filled optional fields.",
    
    "input_schema": {
      "type": "object",
      "properties": {
        "form_id": {"type": "string"},
        "fields": {
          "type": "object",
          "properties": {
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string"},
            "phone": {"type": "string"},
            "email": {"type": "string"},
            "emergency_contact": {"type": "string"},
            "emergency_phone": {"type": "string"},
            "allergies": {"type": "string"},
            "current_medications": {"type": "string"},
            "medical_conditions": {"type": "string"},
            "primary_care_physician": {"type": "string"},
            "insurance_provider": {"type": "string"},
            "policy_number": {"type": "string"}
          }
        }
      }
    },
    
    "output_schema": {
      "type": "object",
      "properties": {
        "form_id": {"type": "string"},
        "patient": {
          "type": "object",
          "properties": {
            "first_name": {"type": "string"},
            "last_name": {"type": "string"},
            "dob": {"type": "string"},
            "phone": {"type": "string"},
            "email": {"type": "string"}
          }
        },
        "emergency_contact": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "phone": {"type": "string"}
          }
        },
        "medical_info": {
          "type": "object",
          "properties": {
            "allergies": {"type": "array", "items": {"type": "string"}},
            "medications": {"type": "array", "items": {"type": "string"}},
            "conditions": {"type": "array", "items": {"type": "string"}},
            "pcp": {"type": "string"}
          }
        },
        "insurance": {
          "type": "object",
          "properties": {
            "provider": {"type": "string"},
            "policy_number": {"type": "string"}
          }
        },
        "validation": {
          "type": "object",
          "properties": {
            "is_valid": {"type": "boolean"},
            "missing_required": {"type": "array", "items": {"type": "string"}},
            "completeness_score": {"type": "integer"}
          }
        }
      }
    }
  },
  
