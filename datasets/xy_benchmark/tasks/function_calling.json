{
  "id": "function_call_01",
  "name": "API Function Selection",
  "description": "Select correct function and parameters for user request",
  "category": "function_calling",
  "difficulty": "medium",
  "prompt_template": "Given these available functions:\n{functions}\n\nUser request: {user_request}\n\nReturn the function call as JSON with 'function' and 'parameters' keys.",
  "evaluation_type": "schema",
  "schema": {
    "type": "object",
    "properties": {
      "function": {"type": "string"},
      "parameters": {"type": "object"}
    },
    "required": ["function", "parameters"]
  },
  "tags": ["function_calling", "api"],
  "instances": [
    {
      "id": "func_001",
      "input": {
        "functions": [
          {"name": "get_weather", "params": {"location": "string", "unit": "celsius|fahrenheit"}},
          {"name": "send_email", "params": {"to": "string", "subject": "string", "body": "string"}},
          {"name": "create_reminder", "params": {"title": "string", "time": "datetime"}}
        ],
        "user_request": "What's the weather in Paris in Celsius?"
      },
      "expected_output": {
        "function": "get_weather",
        "parameters": {"location": "Paris", "unit": "celsius"}
      }
    },
    {
      "id": "func_002",
      "input": {
        "functions": [
          {"name": "get_weather", "params": {"location": "string", "unit": "celsius|fahrenheit"}},
          {"name": "send_email", "params": {"to": "string", "subject": "string", "body": "string"}},
          {"name": "create_reminder", "params": {"title": "string", "time": "datetime"}}
        ],
        "user_request": "Remind me to call mom tomorrow at 3pm"
      },
      "expected_output": {
        "function": "create_reminder",
        "parameters": {"title": "call mom", "time": "tomorrow 3pm"}
      }
    }
  ]
}
